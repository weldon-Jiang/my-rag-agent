{
  "name": "local-knowledge-agent",
  "version": "1.0.0",
  "description": "本地知识库智能体项目",
  "main": "server-nodejs-old/index.js",
  "scripts": {
    "start": "node server-nodejs-old/index.js",
    "dev": "node server-nodejs-old/index.js",
    "go": "powershell -ExecutionPolicy Bypass -File start.ps1",
    "electron": "electron .",
    "build:electron": "set ELECTRON_BUILDER_CACHE=.\\.cache\\electron&& set ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/&& set ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/&& electron-builder --win --dir",
    "build:electron:portable": "set ELECTRON_BUILDER_CACHE=.\\.cache\\electron&& set ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/&& set ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/&& electron-builder --win"
  },
  "build": {
    "appId": "com.chinatravel.myragagent",
    "productName": "MyRagAgent",
    "directories": {
      "output": "dist"
    },
    "asar": false,
    "files": [
      "**/*",
      "!dist/**/*",
      "!.git/**/*",
      "!.trae/**/*",
      "data/**/*",
      "knowledge/**/*",
      ".env"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "win": {
      "target": "portable"
    }
  },
  "keywords": [
    "rag",
    "ai",
    "knowledge-base"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "chromadb": "^3.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.24.7",
    "pdf-parse": "^2.4.5",
    "tesseract.js": "^7.0.0"
  }
}
